# ====================================================================
# 数字人 digital-human 环境变量样例
#
# 使用方法：
#   1. cp .env.example .env
#   2. 填入真实值（切勿提交 .env）
#   3. 启动前导出变量（三选一）：
#        a) 显式 export：  export DB_HOST=... && java -jar app.jar
#        b) 批量导出：    set -a; source .env; set +a  &&  java -jar app.jar
#        c) systemd：     在 unit 文件中加 EnvironmentFile=/path/to/.env
#      注意：单纯 source .env 不会导出到子进程，Java 进程取不到值。
#
# 所有 spring profile (dev/test/uat/prod) 共用同一套变量名，
# 不同环境填入不同的值即可。
# ====================================================================

# ---------- 数据库 (MySQL 8.0) ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=digital-human
DB_USERNAME=digital-human
DB_PASSWORD=__填入真实密码__

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=__填入真实密码__

# ---------- AI (DashScope / 通义千问) ----------
AI_DASHSCOPE_API_KEY=__填入_sk-开头密钥__

# ---------- 阿里云 NLS (语音交互) ----------
ALIYUN_NLS_ACCESS_KEY_ID=__填入__
ALIYUN_NLS_ACCESS_KEY_SECRET=__填入__
ALIYUN_NLS_APP_KEY=__填入__

# ---------- 阿里云 OSS ----------
ALIYUN_OSS_ACCESS_KEY_ID=__填入__
ALIYUN_OSS_ACCESS_KEY_SECRET=__填入__
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=digital-human-new

# ---------- 博尔 API ----------
BOER_ACCESS_KEY=__填入__

# ---------- 文件下载路径（仅 dev） ----------
FILE_DOWNLOAD_PATH=/tmp/digital-human/
